# Copy to `.env` when the dev defaults below are wrong for your setup.
# Must include the `/api` suffix (same as production `https://host/api`).
#
# Defaults in __DEV__ (no .env): iOS → http://127.0.0.1:5000/api,
# Android → http://10.0.2.2:5000/api (emulator → your PC’s backend).

# Physical phone on same Wi‑Fi (replace with your PC’s LAN IP):
# EXPO_PUBLIC_API_URL=http://192.168.1.10:5000/api

# Force remote API while debugging:
# EXPO_PUBLIC_API_URL=https://back.nuxapp.de/api

# Stripe Payment Sheet (wallet top-up). Same publishable key as the website.
# Use EXPO_PUBLIC_* (Expo inlines at build time). Do NOT use NEXT_PUBLIC_* — that is for Next.js only.
# EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- Google Sign-In (native). Same Web Client ID as backend GOOGLE_CLIENT_ID (Google Cloud → OAuth 2.0 → Web client).
# Requires a development/production build (`expo run:ios` / `expo run:android`), not Expo Go.
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=xxxxx.apps.googleusercontent.com
# iOS OAuth client id (Google Cloud → iOS client), same project as the web client:
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=yyyyy.apps.googleusercontent.com
# Optional: native OAuth client ids. If omitted, the app uses EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID for Expo Go (matches backend).
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=zzzzz.apps.googleusercontent.com
# iOS URL scheme for prebuild: reverse the iOS client id → com.googleusercontent.apps.yyyyy
# GOOGLE_IOS_URL_SCHEME=com.googleusercontent.apps.yyyyy
# Native builds: add OAuth client type "Android" with package com.lolity.app and SHA-1 (debug + release).

# --- Google Maps (react-native-maps). Required for opening restaurant location from ads/promotions.
# Create a key with "Maps SDK for Android" enabled; restrict by package + SHA-1 in production.
# GOOGLE_MAPS_API_KEY=AIza...

# --- GitHub Actions (.github/workflows/build-apk.yml)
# Repo → Settings → Secrets → Actions. The workflow does not read `.env` on the runner (EXPO_NO_DOTENV).
# Add the same variables as secrets (names must match):
#   GOOGLE_MAPS_API_KEY
#   EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID
#   EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID   (optional but recommended for release)
#   EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY
#   EXPO_PUBLIC_API_URL
# After changing secrets, re-run the workflow; release APK must be rebuilt (values are baked into the binary/bundle).
